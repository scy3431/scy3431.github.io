    <script is:inline>
      const buttons = document.querySelectorAll('.filter-btn');
      const projects = document.querySelectorAll('.project-item[data-tags]');
      const countEl = document.querySelector('.project-count');

      const updateProjects = (filter) => {
        let visible = 0;
        projects.forEach((project) => {
          const tags = (project.dataset.tags || '').split(' ');
          const show = filter === 'all' || tags.includes(filter);
          project.hidden = !show;
          if (show) visible += 1;
        });
        if (countEl) countEl.textContent = `${visible} project${visible === 1 ? '' : 's'} shown`;
      };

      buttons.forEach((button) => {
        button.addEventListener('click', () => {
          buttons.forEach((btn) => btn.classList.remove('active'));
          button.classList.add('active');
          updateProjects(button.dataset.filter);
        });
      });

      updateProjects('all');
    </script>
